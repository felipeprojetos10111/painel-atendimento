generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model clientes {
  id                 Int                 @id @default(autoincrement())
  nome               String              @db.VarChar(150)
  slug               String              @unique @db.VarChar(50)
  whatsapp_token     String?             @db.Text
  phone_number_id    String?             @db.VarChar(50)
  app_secret         String?             @db.Text
  verify_token       String?             @db.VarChar(100)
  ia_api_key         String?             @db.Text
  webhook_secret     String?             @db.VarChar(100)
  plataforma_base_url String?            @db.Text
  ativo              Boolean             @default(true)
  criado_em          DateTime?           @default(now()) @db.Timestamp(6)
  operadores         operadores[]
  leads              leads[]
  conversas          conversas[]
  config_ia          config_ia[]
  respostas_rapidas  respostas_rapidas[]
  filas              filas[]
  links_enviados     links_enviados[]
  eventos_plataforma eventos_plataforma[]
}

model conversas {
  id            Int         @id @default(autoincrement())
  cliente_id    Int
  lead_id       Int?
  operador_id   Int?
  status        String?     @default("aguardando") @db.VarChar(20)
  canal         String?     @default("whatsapp") @db.VarChar(20)
  nao_lidas            Int?        @default(0)
  criado_em            DateTime?   @default(now()) @db.Timestamp(6)
  atualizado_em        DateTime?   @default(now()) @db.Timestamp(6)
  ultima_mensagem_em   DateTime?   @db.Timestamp(6)
  clientes      clientes    @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  leads         leads?      @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operadores    operadores? @relation(fields: [operador_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  filas         filas[]
  mensagens     mensagens[]
  links_enviados links_enviados[]
}

model filas {
  id          Int        @id @default(autoincrement())
  cliente_id  Int
  conversa_id Int?
  prioridade  Int?       @default(0)
  motivo      String?    @db.VarChar(100)
  criado_em   DateTime?  @default(now()) @db.Timestamp(6)
  clientes    clientes   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  conversas   conversas? @relation(fields: [conversa_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model leads {
  id            Int         @id @default(autoincrement())
  cliente_id    Int
  telefone      String      @db.VarChar(20)
  nome          String?     @db.VarChar(100)
  email         String?     @db.VarChar(150)
  criado_em     DateTime?   @default(now()) @db.Timestamp(6)
  atualizado_em DateTime?   @default(now()) @db.Timestamp(6)
  clientes           clientes    @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  conversas          conversas[]
  links_enviados     links_enviados[]
  eventos_plataforma eventos_plataforma[]

  @@unique([cliente_id, telefone])
}

model mensagens {
  id          Int        @id @default(autoincrement())
  conversa_id Int?
  origem      String     @db.VarChar(20)
  conteudo    String
  tipo        String?    @default("texto") @db.VarChar(20)
  url_midia   String?
  whatsapp_id String?    @db.VarChar(100)
  status      String?    @db.VarChar(20)
  enviado_em  DateTime?  @default(now()) @db.Timestamp(6)
  conversas   conversas? @relation(fields: [conversa_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model operadores {
  id                Int                 @id @default(autoincrement())
  cliente_id        Int
  nome              String              @db.VarChar(100)
  email             String              @unique @db.VarChar(150)
  senha_hash        String              @db.VarChar(255)
  nivel             String?             @default("operador") @db.VarChar(20)
  ativo             Boolean?            @default(true)
  lingua            String?             @default("pt") @db.VarChar(5)
  link_plataforma   String?             @db.Text
  affiliate_link_id String?             @db.VarChar(100)
  mensagem_link     String?             @db.Text
  criado_em         DateTime?           @default(now()) @db.Timestamp(6)
  clientes           clientes            @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  conversas          conversas[]
  respostas_rapidas  respostas_rapidas[]
  links_enviados     links_enviados[]
  eventos_plataforma eventos_plataforma[]
}

model config_ia {
  id                  Int       @id @default(autoincrement())
  cliente_id          Int       @unique
  ativo               Boolean   @default(true)
  modo_distribuicao   String    @default("ia") @db.VarChar(20)
  modelo              String    @default("claude-sonnet-4-6") @db.VarChar(60)
  prompt_sistema      String    @db.Text
  idioma_resposta     String    @default("auto") @db.VarChar(10)
  max_rodadas         Int       @default(5)
  criterios_escalacao String[]
  ia_provedor         String    @default("anthropic") @db.VarChar(20)
  ia_api_key          String?   @db.Text
  atualizado_em       DateTime? @default(now()) @db.Timestamp(6)
  atualizado_por      String?   @db.VarChar(100)
  clientes            clientes  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
}

model links_enviados {
  codigo       String?    @db.VarChar(50)
  id          Int        @id @default(autoincrement())
  cliente_id  Int
  operador_id Int?
  lead_id     Int?
  conversa_id Int?
  enviado_em  DateTime?  @default(now()) @db.Timestamp(6)
  clientes    clientes   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  operadores  operadores? @relation(fields: [operador_id], references: [id], onDelete: SetNull)
  leads       leads?      @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  conversas   conversas?  @relation(fields: [conversa_id], references: [id], onDelete: SetNull)
  eventos_plataforma eventos_plataforma[]
}

model eventos_plataforma {
  id                   Int              @id @default(autoincrement())
  cliente_id           Int
  lead_id              Int?
  operador_id          Int?
  link_enviado_id      Int?
  tipo                 String           @db.VarChar(20)
  plataforma_event_id  String?          @db.VarChar(100)
  plataforma_user_id   String?          @db.VarChar(100)
  email                String?          @db.VarChar(150)
  nome_usuario         String?          @db.VarChar(150)
  telefone             String?          @db.VarChar(50)
  affiliate_link_id    String?          @db.VarChar(100)
  valor                Decimal?         @db.Decimal(12, 2)
  is_primeiro_deposito Boolean?
  metodo_pagamento     String?          @db.VarChar(50)
  moeda                String?          @db.VarChar(10)
  payload              Json?
  data_evento          DateTime?        @db.Timestamp(6)
  criado_em            DateTime?        @default(now()) @db.Timestamp(6)
  clientes             clientes         @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  leads                leads?           @relation(fields: [lead_id], references: [id], onDelete: SetNull)
  operadores           operadores?      @relation(fields: [operador_id], references: [id], onDelete: SetNull)
  links_enviados       links_enviados?  @relation(fields: [link_enviado_id], references: [id], onDelete: SetNull)
}

model respostas_rapidas {
  id          Int        @id @default(autoincrement())
  cliente_id  Int
  operador_id Int
  titulo      String     @db.VarChar(150)
  tipo        String     @default("texto") @db.VarChar(20)
  conteudo    String?
  url_midia   String?
  categoria   String?    @db.VarChar(80)
  atalho      String?    @db.VarChar(50)
  ativo       Boolean?   @default(true)
  criado_em   DateTime?  @default(now()) @db.Timestamp(6)
  clientes    clientes   @relation(fields: [cliente_id], references: [id], onDelete: Cascade)
  operadores  operadores @relation(fields: [operador_id], references: [id], onDelete: Cascade)

  @@unique([operador_id, atalho])
}
